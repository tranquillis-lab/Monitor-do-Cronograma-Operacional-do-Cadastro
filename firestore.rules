rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // ---------------------------------------------------------
    // HELPER FUNCTIONS
    // ---------------------------------------------------------
    
    function isSignedIn() {
      return request.auth != null;
    }

    // Since the app uses anonymous sign-in, we allow anonymous.
    // If we want to restrict to specific emails, we check token.email.
    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Super Admin helper (immutable authority)
    function isSuperAdmin() {
      return isSignedIn() && request.auth.token.email == 'tranquillis@gmail.com';
    }

    // Admin helper checks super admin or the admins collection
    function isAdmin() {
      return isSuperAdmin() || (isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.token.email)));
    }

    // ---------------------------------------------------------
    // VALIDATION BLUEPRINTS
    // ---------------------------------------------------------

    function isValidEvent(data) {
      let requiredFields = ['date', 'title', 'month'];
      return data.keys().hasAll(requiredFields) &&
             data.date is string && data.date.size() <= 10 &&
             data.title is string && data.title.size() <= 500 &&
             data.month is string && data.month.size() <= 100 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 10000));
    }

    function isValidTask(data) {
      let requiredFields = ['eventId', 'description', 'responsible'];
      return data.keys().hasAll(requiredFields) &&
             data.eventId is string && data.eventId.size() <= 128 &&
             data.description is string && data.description.size() <= 2000 &&
             data.responsible is string && data.responsible.size() <= 100 &&
             (!('requiresCompliance' in data) || data.requiresCompliance is bool) &&
             (!('status' in data) || data.status in ['pending', 'completed']);
    }

    function isValidZone(data) {
      return data.keys().hasAll(['id', 'municipality']) &&
             data.id is string && data.id.size() <= 50 &&
             data.municipality is string && data.municipality.size() <= 500;
    }

    function isValidCompliance(data) {
      return data.keys().hasAll(['zoneId', 'taskId', 'status']) &&
             data.zoneId is string && data.taskId is string &&
             data.status in ['pending', 'completed'] &&
             (!('updatedAt' in data) || data.updatedAt is string) &&
             (!('evidenceUrl' in data) || data.evidenceUrl is string) &&
             (!('notes' in data) || (data.notes is string && data.notes.size() <= 5000));
    }

    function isValidDocument(data) {
      return data.keys().hasAll(['relatedId', 'name', 'url', 'type']) &&
             data.relatedId is string &&
             data.name is string && data.name.size() <= 500 &&
             data.url is string && data.url.size() <= 2000 &&
             data.type in ['file', 'link'] &&
             (!('eventId' in data) || data.eventId is string) &&
             (!('uploadedAt' in data) || data.uploadedAt is string);
    }

    function isValidResponsibleUnit(data) {
      return data.keys().hasAll(['name', 'acronym']) &&
             data.name is string && data.name.size() <= 500 &&
             data.acronym is string && data.acronym.size() <= 50 &&
             (!('description' in data) || (data.description is string && data.description.size() <= 2000));
    }

    function isValidAdmin(data) {
      return data.keys().hasAll(['email']) &&
             data.email is string && data.email.size() <= 200 &&
             (!('createdAt' in data) || data.createdAt is string);
    }

    // ---------------------------------------------------------
    // SCHEMA SYNC (REPLACEABLE BY DRAFT)
    // ---------------------------------------------------------

    // Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // Connection test collection MUST be allowed for system health
    match /test/connection {
      allow read: if true;
    }

    match /events/{eventId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    match /tasks/{taskId} {
      allow read: if true;
      allow create: if isAdmin();
      allow update: if isSignedIn() && (
        isAdmin() ||
        incoming().diff(existing()).affectedKeys().hasOnly(['status'])
      ); // Allow non-admins to ONLY update status if they are signed in (optional, but requested restriction was "only me or someone I permit", let's be strict first)
      allow delete: if isAdmin();
    }

    match /zones/{zoneId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /compliance/{complianceId} {
      allow read: if true;
      allow create: if isSignedIn(); // Zone users might need this
      allow update: if isSignedIn();
      allow delete: if isAdmin();
    }

    match /documents/{docId} {
      allow read: if true;
      allow create: if isSignedIn();
      allow update: if isAdmin() || (isSignedIn() && incoming().diff(existing()).affectedKeys().hasOnly(['name', 'url', 'type', 'uploadedAt']));
      allow delete: if isAdmin();
    }

    match /responsibleUnits/{unitId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    match /admins/{adminId} {
      allow read: if isSignedIn();
      allow write: if isSuperAdmin();
    }
  }
}
